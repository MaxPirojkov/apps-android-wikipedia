name: "Multi-project Android tests"
outputDir: "build/reports/marathon"
isCodeCoverageEnabled: true
batchingStrategy:
  type: "fixed-size"
  size: 5
retryStrategy:
  type: "fixed-quota"
  totalAllowedRetryQuota: 100
  retryPerTestQuota: 2
uncompletedTestRetryQuota: 1
deviceInitializationTimeoutMillis: 180000
vendorConfiguration:
  type: "Android"
  outputs:
  - application: "/Users/maxim.pirozhkov/Documents/GitHub/apps-android-wikipedia/app/build/outputs/apk/alpha/debug/app-alpha-debug.apk"
    testApplication: "/Users/maxim.pirozhkov/Documents/GitHub/apps-android-wikipedia/app/build/outputs/apk/androidTest/alpha/debug/app-alpha-debug-androidTest.apk"
  autoGrantPermission: true
  instrumentationArgs:
    debug: "false"
  applicationPmClear: true
  waitForDevicesTimeoutMillis: 60000
  allureConfiguration:
    enabled: true
    relativeResultsDirectory: "Documents/allure-results"
    pathRoot: "EXTERNAL_STORAGE"
filteringConfiguration:
  allowlist:
    - type: "fully-qualified-test-name"
      values:
        - "org.wikipedia.works.lesson29.AuthorizeTest#authorize"
        - "org.wikipedia.works.lesson28.SampleTest#testIdFirst"
        - "org.wikipedia.works.lesson28.SampleTest#testIdSecond"
        - "org.wikipedia.works.lesson27.SuccessAllureScreenshotTest#screenShotSuccess"
shardingStrategy:
  type: "parallel"